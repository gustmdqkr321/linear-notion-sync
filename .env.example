# 이 파일을 .env 로 복사(cp .env.example .env)해서 아래 4개만 채우면 동작합니다.
# .env 는 커밋되지 않습니다(.gitignore).

# ===== 필수 =====
# Linear Personal API key — Settings > Security & access > Personal API keys (admin 불필요)
LINEAR_API_KEY=lin_api_xxx
# 동기화할 Linear 프로젝트 ID (모르면 README의 목록 조회 명령 참고)
LINEAR_PROJECT_ID=

# Notion Internal integration secret — my-integrations
NOTION_TOKEN=ntn_xxx
# 캘린더로 쓸 Notion DB ID (DB URL의 ?v= 앞 32자리)
NOTION_DATABASE_ID=

# ===== 선택 (기본값 있음) =====
# 폴링 주기(ms). 기본 60000
# POLL_INTERVAL_MS=10000

# Notion DB 속성 이름. 기본값이 아래와 같음 — DB 컬럼명이 다르면만 덮어쓰기.
# 값을 빈 문자열로 두면 그 속성은 동기화 안 함.
# PROP_TITLE=제목
# PROP_DATE=일정
# PROP_ASSIGNEE=담당            (Person 타입)
# PROP_URL=Linear 링크          (URL 타입)
# PROP_MILESTONE=마일스톤        (Select 타입)
# PROP_TYPE=Type                (Select: Issue/서브이슈/마일스톤)
# PROP_PARENT=상위 issue         (Text 타입)
